BOID_RAP_RETRIEVAL_CACHE_TTL_SECONDS=3600

BOID_RAP_OPENAI_LLM_ENABLED=false
BOID_RAP_OPENAI_API_KEY=
BOID_RAP_OPENAI_BASE_URL=https://api.openai.com/v1
# OpenRouter example:
# BOID_RAP_OPENAI_BASE_URL=https://openrouter.ai/api/v1
# BOID_RAP_OPENAI_MODEL=openai/gpt-5-mini
# BOID_RAP_OPENAI_API_KEY=sk-or-v1-...
BOID_RAP_OPENAI_ENDPOINT=
BOID_RAP_OPENAI_MODEL=gpt-5-mini
BOID_RAP_OPENAI_TIMEOUT=20

BOID_RAP_TAVILY_ENABLED=false
BOID_RAP_TAVILY_API_KEY=
BOID_RAP_TAVILY_ENDPOINT=https://api.tavily.com/search
BOID_RAP_TAVILY_TIMEOUT=10
BOID_RAP_TAVILY_MAX_RESULTS=5
BOID_RAP_TAVILY_INCLUDE_RAW_CONTENT=text
BOID_RAP_TAVILY_INCLUDE_FAVICON=true
BOID_RAP_TAVILY_SEARCH_DEPTH=basic

BOID_RAP_HTTP_RETRIEVAL_ENABLED=false
BOID_RAP_HTTP_RETRIEVAL_ENDPOINT=https://api.example.com/deepsearch
BOID_RAP_HTTP_RETRIEVAL_METHOD=POST
BOID_RAP_HTTP_RETRIEVAL_TIMEOUT=10
BOID_RAP_HTTP_RETRIEVAL_API_KEY=
BOID_RAP_HTTP_RETRIEVAL_API_KEY_HEADER=Authorization

# JSON object. Example:
# {"query":"{{object_name}}","type":"{{object_type}}","filters":{"focus":"{{focus_areas}}","window":"{{time_range}}"}}
BOID_RAP_HTTP_RETRIEVAL_REQUEST_TEMPLATE=null

# JSON object. Example:
# {"X-Source":"boid-rap","X-Env":"dev"}
BOID_RAP_HTTP_RETRIEVAL_REQUEST_HEADERS={}

# JSON object. Example:
# {"documents_path":"data.hits","provider_path":"meta.providerName","object_name_path":"meta.subject","object_type_path":"meta.kind","created_at_path":"meta.generatedAt","document_fields":{"title":"headline","summary":"abstract","source":"site","url":"href","published_at":"published","tags":"labels"}}
BOID_RAP_HTTP_RETRIEVAL_RESPONSE_MAPPING={}
